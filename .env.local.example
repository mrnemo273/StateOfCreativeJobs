# Adzuna API — Free at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# GNews API — Free at https://gnews.io/
GNEWS_API_KEY=

# BLS API — Free, optional key at https://www.bls.gov/developers/
# Works without key (25 requests/day), with key (500/day)
BLS_API_KEY=

# SerpApi — Google Trends data — https://serpapi.com/
SERPAPI_KEY=

# O*NET Web Services — Free at https://services.onetcenter.org/
ONET_API_KEY=

# Anthropic API — Role Intelligence + Editorial synthesis
ANTHROPIC_API_KEY=

# Refresh secret — used by snapshot refresh scripts
REFRESH_SECRET=

# Resend — Email digest service — https://resend.com/
RESEND_API_KEY=

# Upstash Redis — Subscriber storage for email digest
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Site URL — used in email templates and digest links
SITE_URL=https://creative-jobs.juanemo.com
